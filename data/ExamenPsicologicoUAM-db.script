CREATE SCHEMA PUBLIC AUTHORIZATION DBA
CREATE MEMORY TABLE PUBLIC.CUESTIONARIO(ID VARCHAR(255) NOT NULL PRIMARY KEY,DESCRIPCION VARCHAR(1000),EJEMPLO VARCHAR(255),INSTRUCCIONES VARCHAR(1000),NOMBRE VARCHAR(255))
CREATE MEMORY TABLE PUBLIC.IMAGES(ID VARCHAR(32) NOT NULL PRIMARY KEY,GALLERY VARCHAR(32),IMAGE VARBINARY(16777216))
CREATE MEMORY TABLE PUBLIC.OXDISCUSSIONCOMMENTS(ID VARCHAR(32) NOT NULL PRIMARY KEY,"COMMENT" CLOB(16M),DISCUSSIONID VARCHAR(32),TIME TIMESTAMP,USERNAME VARCHAR(30))
CREATE INDEX IDXBHLX4VUNN24YM1TBRLGQ8G30M ON PUBLIC.OXDISCUSSIONCOMMENTS(DISCUSSIONID)
CREATE MEMORY TABLE PUBLIC.PREGUNTA(ID VARCHAR(255) NOT NULL PRIMARY KEY,ENUNCIADO VARCHAR(1000),ESEJEMPLO BOOLEAN NOT NULL,NUMERO INTEGER NOT NULL,OPCIONA VARCHAR(1000),OPCIONB VARCHAR(1000),OPCIONC VARCHAR(1000),OPCIOND VARCHAR(1000),OPCIONE VARCHAR(1000),RESPUESTACORRECTA VARCHAR(1),CUESTIONARIO_ID VARCHAR(255) NOT NULL,CONSTRAINT FKUWRO104SOHWDL1BEMKIUVHLM FOREIGN KEY(CUESTIONARIO_ID) REFERENCES PUBLIC.CUESTIONARIO(ID))
CREATE MEMORY TABLE PUBLIC.SUJETO(ID VARCHAR(255) NOT NULL PRIMARY KEY,EDAD INTEGER NOT NULL,ESTUDIOSREALIZADOS VARCHAR(255),FECHANACIMIENTO DATE,NOMBRE VARCHAR(255),PRIMERAPELLIDO VARCHAR(255),PROFESION VARCHAR(255),SEGUNDOAPELLIDO VARCHAR(255),SEXO VARCHAR(255),NOMBRES VARCHAR(255))
CREATE MEMORY TABLE PUBLIC.APLICACIONPRUEBA(ID VARCHAR(255) NOT NULL PRIMARY KEY,ESTADO VARCHAR(255),FECHAAPLICACION DATE,HORAINICIO TIMESTAMP,CUESTIONARIO_ID VARCHAR(255) NOT NULL,SUJETO_ID VARCHAR(255) NOT NULL,CONSTRAINT FKN2Y64NVK67YD6WVV2MUXYRJGD FOREIGN KEY(CUESTIONARIO_ID) REFERENCES PUBLIC.CUESTIONARIO(ID),CONSTRAINT FKCCKROLYCKNPIEUFFTEKT8DSC1 FOREIGN KEY(SUJETO_ID) REFERENCES PUBLIC.SUJETO(ID))
CREATE MEMORY TABLE PUBLIC.RESPUESTASUJETO(ID VARCHAR(255) NOT NULL PRIMARY KEY,RESPUESTASELECCIONADA VARCHAR(1),APLICACIONPRUEBA_ID VARCHAR(255) NOT NULL,PREGUNTA_ID VARCHAR(255) NOT NULL,CONSTRAINT FKCSTNSAKUHBVCJK2C0QE9HU2AU FOREIGN KEY(APLICACIONPRUEBA_ID) REFERENCES PUBLIC.APLICACIONPRUEBA(ID),CONSTRAINT FKHHB1CFQ1E6K8M8AVYQ5X7HJ5I FOREIGN KEY(PREGUNTA_ID) REFERENCES PUBLIC.PREGUNTA(ID))
