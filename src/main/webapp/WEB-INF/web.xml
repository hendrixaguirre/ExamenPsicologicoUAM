<!DOCTYPE web-app PUBLIC
        "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
        "http://java.sun.com/dtd/web-app_2_3.dtd" >

<web-app>
  <display-name>OpenXava Application</display-name>

  <!-- Siembra las 31 preguntas al arrancar la aplicación -->
  <listener>
    <listener-class>ni.edu.uam.ExamenPsicologicoUAM.run.CargadorDatos</listener-class>
  </listener>

  <!-- Evitar problema de bloqueo de archivos de IntelliJ en Windows -->
  <servlet>
    <servlet-name>jsp</servlet-name>
    <servlet-class>org.apache.jasper.servlet.JspServlet</servlet-class>
    <init-param>
      <param-name>suppressSmap</param-name>
      <param-value>true</param-value>
    </init-param>
    <load-on-startup>3</load-on-startup>
  </servlet>

  <!-- Entrega las preguntas (sin clave) e inicia la aplicación -->
  <servlet>
    <servlet-name>IniciarPrueba</servlet-name>
    <servlet-class>ni.edu.uam.ExamenPsicologicoUAM.web.IniciarPruebaServlet</servlet-class>
  </servlet>

  <!-- Recibe las respuestas, califica y devuelve el resultado -->
  <servlet>
    <servlet-name>CalificarPrueba</servlet-name>
    <servlet-class>ni.edu.uam.ExamenPsicologicoUAM.web.CalificarPruebaServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>jsp</servlet-name>
    <url-pattern>*.jsp</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>IniciarPrueba</servlet-name>
    <url-pattern>/api/iniciar</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>CalificarPrueba</servlet-name>
    <url-pattern>/api/calificar</url-pattern>
  </servlet-mapping>

  <!-- Para cumplir con OWASP -->
  <error-page>
    <error-code>404</error-code>
    <location>/WEB-INF/error404.html</location>
  </error-page>
  <error-page>
    <error-code>500</error-code>
    <location>/WEB-INF/error500.html</location>
  </error-page>

</web-app>